# open-meet-docker — local-dev defaults consumed by docker compose interpolation.
# These are NOT production secrets. Rotate everything before deploying anywhere real.

# LiveKit — key name + shared secret. The same pair is injected into the
# livekit, egress and server containers so room tokens and webhooks line up.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_LpQ7Rk2sVz9XwT4mNb8YcF3hJ6dG1aQeR5uW0iO

# JWTs (min 16 chars). User access/refresh + a separate admin-console secret.
JWT_ACCESS_SECRET=dev-access-secret-change-me-0123456789
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-0123456789
ADMIN_JWT_ACCESS_SECRET=dev-admin-access-secret-change-me-0123456789

# Default admin, auto-created by the API on first boot when none exists.
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=admin12345
DEFAULT_ADMIN_NAME=Example

# Google OAuth (optional — leave empty to disable social login).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
