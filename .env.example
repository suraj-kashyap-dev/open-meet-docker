# Copy to .env and adjust. setup.sh does this automatically when .env is missing.
# Local-dev defaults — NOT production secrets.

# LiveKit — key name + shared secret (same pair across livekit/egress/server).
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=change-me-to-a-long-random-secret

# JWTs (min 16 chars each).
JWT_ACCESS_SECRET=change-me-access-0123456789
JWT_REFRESH_SECRET=change-me-refresh-0123456789
ADMIN_JWT_ACCESS_SECRET=change-me-admin-access-0123456789

# Default admin, auto-created by the API on first boot.
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=admin12345
DEFAULT_ADMIN_NAME=Example

# Google OAuth (optional).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
